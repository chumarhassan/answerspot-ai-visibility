# Frontend config (Vite exposes only VITE_*-prefixed vars to the browser).
# The API base; leave blank to use the dev proxy in vite.config.js.
VITE_API_URL=

# Google OAuth client id (PUBLIC — safe to expose). The client SECRET stays
# server-side only. Must match GOOGLE_OAUTH_CLIENT_ID in the backend .env.
VITE_GOOGLE_CLIENT_ID=
