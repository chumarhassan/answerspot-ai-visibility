# ── Answerspot backend configuration ──────────────────────────────────────────
# Copy to `.env` and fill in. NEVER commit the real .env (it is gitignored).

# Database. Default is local SQLite (zero setup). For prod, swap to Postgres:
#   DATABASE_URL=postgresql+psycopg://user:pass@host:5432/answerspot
DATABASE_URL=sqlite:///./answerspot.db

# JWT signing secret — generate a long random string, e.g. `openssl rand -hex 32`
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_MINUTES=10080

# ── Gemini (the ONLY tracked AI platform for MVP — free tier) ─────────────────
# Get a free key at https://aistudio.google.com/apikey
# IMPORTANT (§4): do NOT enable billing on this Google project — that destroys
# the free tier. Free tier is fine for US-focused use; serving EEA/UK end-users
# would require a paid plan.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# ── Google OAuth (for "Continue with Google") ─────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/auth/google/callback

# ── Stripe (TEST MODE ONLY until you say go-live) ─────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...

# Frontend origin (for CORS + Stripe redirect URLs)
FRONTEND_URL=http://localhost:5173
